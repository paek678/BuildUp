  m_Script: {fileID: 11500000, guid: 1d6996db100ef0649889669dbb5b760f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  narrationPanel: {fileID: 1742211443}
  narrationNameText: {fileID: 1693741897}
  narrationDialogueText: {fileID: 2057575612}
  character1Panel: {fileID: 622393659}
  character1NameText: {fileID: 590666640}
  character1DialogueText: {fileID: 1819819564}
  character2Panel: {fileID: 1780007325}
  character2NameText: {fileID: 652457908}
  character2DialogueText: {fileID: 672307481}
  character3Panel: {fileID: 1890192510}
  character3NameText: {fileID: 590666640}
  character3DialogueText: {fileID: 1819819564}
  introText: {fileID: 720572303}
  fadeDuration: 1.5
  holdTime: 2
  endPrefab: {fileID: 273787811}
  nextSceneName: Chapter1
  dialogueLines:
  - speaker: Narration
    name: 
    sentence: "\uC5B8\uC81C \uBD80\uD130\uC600\uC744\uAE4C, \uB208\uC5D0 \uC544\uBB34\uAC83\uB3C4
      \uC7A1\uD788\uC9C0 \uC54A\uAC8C\uB41C\uAC74."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uC544\uB4DD\uD574\uC9C0\uB294 \uC5B4\uB460 \uC18D\uC5D0 \uC11C\uC11C\uD788
      \uB179\uC544\uB4E4\uAC8C \uB418\uB294 \uC21C\uAC04."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uB098\uC5D0\uAC8C \uC5B4\uB5A0\uD55C \uC874\uC7AC\uAC00 \uB2E4\uAC00\uC640
      \uAE30\uCC99\uC744 \uB0B4\uB294 \uAC83\uC744 \uB290\uAF08\uB2E4."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Character1
    name: M
    sentence: "\uC55E\uC5D0...  \uB204\uAD6C \uC788\uC5B4?"
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Character2
    name: W
    sentence: "\uC55E\uC5D0 \uB204\uAD6C... \uC788\uC5B4?"
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uBA54\uC544\uB9AC. \uB9C8\uCE58 \uBA54\uC544\uB9AC\uAC00 \uB3CC\uC544\uC624\uB4EF
      \uADC0\uC5D0 \uC6B8\uB824\uD37C\uC9C4\uB2E4."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uC544\uBB34\uB9AC \uAFC8\uC18D\uC774\uB77C\uC9C0\uB9CC, \uC774\uAC74
      \uB108\uBB34 \uBE44\uD604\uC2E4 \uC801\uC774\uC9C0 \uC54A\uC740\uAC00."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Character2
    name: W
    sentence: "\uC774\uB9AC\uB85C \uC640. \uB0B4\uAC00 \uB3C4\uC640\uC904\uAC8C"
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uC774\uAC74... \uB098\uB2E4. \uB0B4 \uBAA9\uC18C\uB9AC, \uB0B4 \uB9D0\uD22C "
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Narration
    name: 
    sentence: "\uBB34\uC758\uC2DD\uC801\uC73C\uB85C \uAC70\uC6B8\uC5D0 \uBE68\uB824\uB4E4\uC5B4\uAC00\uB4EF
      \uC190\uC774 \uC62C\uB77C\uAC04\uB2E4."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Character2
    name: W
    sentence: "\uADF8\uB798, \uAC19\uC774 \uAC00\uC790."
    textColor: {r: 1, g: 1, b: 1, a: 1}
  - speaker: Character3
    name: 
    sentence: "\uBAA8\uB4E0 \uAC83\uC740... \uB2E4 [\uC6B0\uB9AC]\uC758 \uC120\uD0DD\uB300\uB85C."
    textColor: {r: 0.20754719, g: 0.0009789985, b: 0.0009789985, a: 1}
  typingSpeed: 0.05
  waitTime: 2
